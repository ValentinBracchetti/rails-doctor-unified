# Copier vers .env.local en développement. Sur Render : Environment → Environment Variables.
# NODE_ENV=production est injecté par Render au runtime (ne pas le forcer au build).

# Obligatoire en production (Render le génère via render.yaml ou à saisir à la main)
JWT_SECRET=

# Recommandé pour Next.js (Server Actions) — même valeur si plusieurs instances
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# Optionnel — sinon défauts dans lib/auth.ts (admin / root)
ADMIN_LOGIN=
ADMIN_PASSWORD=
